rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidSeries(data) {
      return data.keys().hasAll(['id', 'name', 'status', 'userId', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 500 &&
             data.status in ['ongoing', 'completed', 'on_hold', 'dropped'] &&
             data.userId is string && data.userId.size() <= 128 &&
             data.createdAt is number &&
             (!('author' in data) || (data.author is string && data.author.size() <= 500)) &&
             (!('publisher' in data) || (data.publisher is string && data.publisher.size() <= 500)) &&
             (!('coverUrl' in data) || (data.coverUrl is string && data.coverUrl.size() <= 1000)) &&
             (!('totalVolumes' in data) || data.totalVolumes is number);
    }

    function isValidVolume(data) {
      return data.keys().hasAll(['id', 'seriesId', 'volumeNumber', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.seriesId is string && data.seriesId.size() <= 128 &&
             data.volumeNumber is number &&
             data.status in ['owned', 'wishlist'] &&
             data.createdAt is number &&
             (!('purchaseDate' in data) || (data.purchaseDate is string && data.purchaseDate.size() <= 128)) &&
             (!('purchaseSource' in data) || (data.purchaseSource is string && data.purchaseSource.size() <= 500)) &&
             (!('price' in data) || data.price is number) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 2000)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 1000)) &&
             (!('releaseDate' in data) || (data.releaseDate is string && data.releaseDate.size() <= 128));
    }

    match /series/{seriesId} {
      allow read: if request.auth != null && existing().userId == request.auth.uid; 
      allow create: if request.auth != null && isValidId(seriesId) && isValidSeries(incoming()) && incoming().userId == request.auth.uid;
      allow update: if request.auth != null && isValidId(seriesId) && isValidSeries(incoming()) && incoming().userId == request.auth.uid && existing().userId == request.auth.uid;
      allow delete: if request.auth != null && isValidId(seriesId) && existing().userId == request.auth.uid;
    }

    match /volumes/{volumeId} {
      // Need a way to ensure the volume belongs to a series owned by the user,
      // but without a `userId` field on volume, it's hard to verify securely without get().
      // For now, just require the user to be authenticated since this is a prototype.
      allow read: if request.auth != null;
      allow create: if request.auth != null && isValidId(volumeId) && isValidVolume(incoming());
      allow update: if request.auth != null && isValidId(volumeId) && isValidVolume(incoming());
      allow delete: if request.auth != null && isValidId(volumeId);
    }
  }
}